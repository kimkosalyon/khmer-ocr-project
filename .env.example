# Optional MLflow tracking server used by local experiments.
MLFLOW_TRACKING_URI=http://localhost:15005

# Hugging Face upload scripts read either HF_TOKEN or HUGGINGFACE_HUB_TOKEN.
# Never commit real tokens in .env or source files.
HF_TOKEN=your_huggingface_token_here
# HUGGINGFACE_HUB_TOKEN=your_huggingface_token_here
